<!doctype html>
<html lang="{{ lang }}">
<head>
<meta charset="utf-8">
<style>
{{ fontFaceCss | safe }}

:root {
{{ tokenVars | safe }}
}

* { margin: 0; padding: 0; box-sizing: border-box; }
html, body { width: var(--canvas-w); height: var(--canvas-h); }
body { background: #fff; }

.stage {
  position: relative;
  width: var(--canvas-w);
  height: var(--canvas-h);
  overflow: hidden;
  background: var(--slide-bg);
  color: var(--c-fg);
  font-family: var(--ff-serif);
  -webkit-font-smoothing: antialiased;
  text-rendering: geometricPrecision;
}

.stage__bg-img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; z-index: 0; }
.stage__overlay { position: absolute; inset: 0; background: var(--bg-overlay); z-index: 1; }

.watermark {
  position: absolute; top: -0.18em; left: -0.04em;
  font-family: var(--ff-display);
  font-size: 760px; font-weight: 800; line-height: 1;
  color: var(--c-fg); opacity: 0.06; z-index: 1; white-space: nowrap; pointer-events: none;
}

.safe {
  position: absolute;
  inset: var(--safe-top) var(--safe-right) var(--safe-bottom) var(--safe-left);
  z-index: 2;
  display: flex; flex-direction: column;
  justify-content: {% block justify %}center{% endblock %};
  gap: 28px;
}

/* accent plaque on highlighted words */
.plaque {
  background: var(--plaque-bg); color: var(--plaque-fg);
  padding: var(--plaque-py) var(--plaque-px);
  -webkit-box-decoration-break: clone; box-decoration-break: clone;
}

.eyebrow { font-family: var(--t-eyebrow-family); font-size: var(--t-eyebrow-size); font-weight: var(--t-eyebrow-weight); line-height: var(--t-eyebrow-lh); letter-spacing: var(--t-eyebrow-tracking); text-transform: var(--t-eyebrow-case); color: var(--t-eyebrow-color); }
.kicker  { font-family: var(--t-kicker-family); font-size: var(--t-kicker-size); font-weight: var(--t-kicker-weight); letter-spacing: var(--t-kicker-tracking); text-transform: var(--t-kicker-case); color: var(--t-kicker-color); }
.title   { font-family: var(--t-title-family); font-size: var(--t-title-size); font-weight: var(--t-title-weight); line-height: var(--t-title-lh); text-transform: var(--t-title-case); color: var(--t-title-color); }
.subtitle{ font-family: var(--t-subtitle-family); font-size: var(--t-subtitle-size); font-weight: var(--t-subtitle-weight); line-height: var(--t-subtitle-lh); font-style: var(--t-subtitle-style); color: var(--t-subtitle-color); }
.body    { font-family: var(--t-body-family); font-size: var(--t-body-size); font-weight: var(--t-body-weight); line-height: var(--t-body-lh); color: var(--t-body-color); }
.quote   { font-family: var(--t-quote-family); font-size: var(--t-quote-size); font-weight: var(--t-quote-weight); line-height: var(--t-quote-lh); font-style: var(--t-quote-style); color: var(--t-quote-color); }
.listitem{ font-family: var(--t-listItem-family); font-size: var(--t-listItem-size); font-weight: var(--t-listItem-weight); line-height: var(--t-listItem-lh); color: var(--t-listItem-color); }
.cta     { font-family: var(--t-cta-family); font-size: var(--t-cta-size); font-weight: var(--t-cta-weight); line-height: var(--t-cta-lh); color: var(--t-cta-color); }

.stack { display: flex; flex-direction: column; gap: 24px; }
.body + .body { margin-top: 0.4em; }

.logo { position: absolute; z-index: 3; }
.logo--bottom-left  { left: var(--safe-left);  bottom: var(--safe-bottom); }
.logo--bottom-right { right: var(--safe-right); bottom: var(--safe-bottom); }
.logo--top-left     { left: var(--safe-left);  top: var(--safe-top); }
.logo--top-right    { right: var(--safe-right); top: var(--safe-top); }

.pagenum {
  position: absolute; right: var(--safe-right);
  bottom: calc(var(--safe-bottom) * 0.42);
  font-family: var(--ff-mono); font-size: var(--t-pageNum-size, 24px);
  letter-spacing: 0.14em; color: var(--t-pageNum-color, var(--c-fg)); opacity: 0.85; z-index: 3;
}

{% block style %}{% endblock %}
</style>
</head>
<body>
<div class="stage" style="{{ stageStyle | safe }}">
  {% if bgImage %}<img class="stage__bg-img" src="{{ bgImage }}" alt="">{% endif %}
  {% if bgOverlay %}<div class="stage__overlay" style="--bg-overlay: {{ bgOverlay }}"></div>{% endif %}
  {% if watermark %}<div class="watermark">{{ watermark }}</div>{% endif %}

  <div class="safe">
    {% block content %}{% endblock %}
  </div>

  {% if logo %}<img class="logo logo--{{ logo.placement }}" src="{{ logo.src }}" alt="" style="width: {{ logo.width }}">{% endif %}
  {% if pageNum %}<div class="pagenum">{{ pageNum }}</div>{% endif %}
</div>
</body>
</html>
